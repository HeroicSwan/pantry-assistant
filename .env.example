DATABASE_URL="postgresql://username:password@localhost:5432/food_pantry_dev"
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/food_pantry_test"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
SEED_USER_PASSWORD="replace-with-a-strong-local-test-password"

# Optional SMS provider. Development remains in database-configured simulation mode without these.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_PHONE_NUMBER=""
TWILIO_WEBHOOK_BASE_URL="http://localhost:3000"

# Optional AI provider used elsewhere in the app for document/report generation. Never wired into
# the operations assistant below. Core application works with this disabled.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# Operations assistant model provider: "disabled", "local-deterministic" (default, no model, keyword
# router only), or "ollama" (a locally hosted Ollama server -- no data ever leaves this machine).
# Requires `ollama serve` running locally with the model below pulled (e.g. `ollama pull qwen2.5:7b`).
ASSISTANT_PROVIDER="local-deterministic"
OLLAMA_ASSISTANT_BASE_URL="http://127.0.0.1:11434"
OLLAMA_ASSISTANT_MODEL="qwen2.5:7b"
OLLAMA_ASSISTANT_TIMEOUT_MS="30000"

# Required only when exposing protected scheduled-job routes.
CRON_SECRET="replace-with-at-least-32-random-characters"
