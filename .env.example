DATABASE_URL="postgresql://username:password@localhost:5432/food_pantry_dev"
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/food_pantry_test"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
# Development-only seed credential. Production installs do not seed fictional accounts.
SEED_USER_PASSWORD="replace-with-a-strong-local-development-password"

# Optional SMS provider. Development remains in database-configured simulation mode without these.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_MESSAGING_SERVICE_SID=""
TWILIO_PHONE_NUMBER=""
TWILIO_WEBHOOK_BASE_URL="http://localhost:3000"

# Optional SMS provider credentials. Select the provider per pantry location in Messaging settings.
VONAGE_API_KEY=""
VONAGE_API_SECRET=""
PLIVO_AUTH_ID=""
PLIVO_AUTH_TOKEN=""
TELNYX_API_KEY=""
TELNYX_MESSAGING_PROFILE_ID=""
SINCH_SERVICE_PLAN_ID=""
SINCH_API_TOKEN=""
INFOBIP_BASE_URL=""
INFOBIP_API_KEY=""
BANDWIDTH_API_TOKEN=""
BANDWIDTH_API_SECRET=""
BANDWIDTH_APPLICATION_ID=""
BIRD_ACCESS_KEY=""
BIRD_WORKSPACE_ID=""
BIRD_CHANNEL_ID=""
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SNS_SENDER_ID=""
AZURE_COMMUNICATION_CONNECTION_STRING=""
SMS_WEBHOOK_SECRET="replace-with-at-least-32-random-characters"

# Optional SMTP delivery for password resets and invitations. If blank, links are stored in the
# local development message inbox so a self-hosted installation remains usable without email.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_SECURE="false"

# Optional AI provider used elsewhere in the app for document/report generation. Never wired into
# the operations assistant below. Core application works with this disabled.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# Operations assistant model provider: "disabled", "local-deterministic" (default, no model, keyword
# router only), or "ollama" (a locally hosted Ollama server -- no data ever leaves this machine).
# Requires `ollama serve` running locally with the model below pulled (e.g. `ollama pull qwen2.5:7b`).
ASSISTANT_PROVIDER="local-deterministic"
OLLAMA_ASSISTANT_BASE_URL="http://127.0.0.1:11434"
OLLAMA_ASSISTANT_MODEL="qwen2.5:7b"
OLLAMA_ASSISTANT_TIMEOUT_MS="30000"
AI_CONVERSATION_RETENTION_DAYS="90"
ASSISTANT_AUTONOMOUS_WRITES_ENABLED="false"

# Required only when exposing protected scheduled-job routes.
CRON_SECRET="replace-with-at-least-32-random-characters"
