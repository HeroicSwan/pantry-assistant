{
  "name": "pantry-assistant",
  "version": "0.1.0-rc.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3000",
    "selfhost:package": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1",
    "selfhost:setup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-self-hosted.ps1",
    "selfhost:uninstall": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-self-hosted.ps1",
    "selfhost:backup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/backup-self-hosted.ps1",
    "selfhost:restore": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/restore-self-hosted.ps1",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db.ts migrate",
    "db:status": "tsx scripts/db.ts status",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:test:migrate": "cross-env NODE_ENV=test tsx scripts/db.ts test-migrate",
    "db:test:status": "cross-env NODE_ENV=test tsx scripts/db.ts test-status",
    "db:test:reset": "cross-env NODE_ENV=test tsx scripts/db.ts test-reset",
    "db:test:seed": "cross-env NODE_ENV=test tsx scripts/db-seed.ts --test",
    "test": "vitest run --exclude tests/integration/**",
    "test:coverage": "vitest run --coverage --exclude tests/integration/**",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "pnpm db:test:reset && pnpm db:test:migrate && pnpm db:test:seed && pnpm build && playwright test",
    "test:db": "pnpm db:test:reset && pnpm db:test:migrate && pnpm db:test:seed && pnpm test:integration",
    "test:jobs": "pnpm test:db",
    "test:sms": "vitest run src/domains/messaging",
    "test:ai": "vitest run src/domains/assistant",
    "test:reports": "vitest run src/domains/reports",
    "test:accessibility": "pnpm db:test:reset && pnpm db:test:migrate && pnpm db:test:seed && pnpm build && playwright test tests/e2e/accessibility.spec.ts",
    "forecast:run-jobs": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/forecast-worker.ts",
    "messaging:run-jobs": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/messaging-worker.ts",
    "appointments:run-jobs": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/appointment-worker.ts",
    "ai:retention": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/ai-retention-worker.ts",
    "reports:exports": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/reports-export-worker.ts",
    "queue:worker": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/queue-worker.ts",
    "ai:writes": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/ai-write-worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.1089.0",
    "@hookform/resolvers": "^5.4.0",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
